module MiniDemo.Asset where

template Asset
  with
    issuer : Party
    owner : Party
    name : Text
    amount : Decimal
  where
    signatory issuer
    observer owner

    choice Transfer : ContractId Asset
      with
        newOwner : Party
      controller owner
      do
        create this with owner = newOwner
